// frontend/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------------
// APPLICATION SCHEMA
// ------------------------------------------------------

model User {
  id           String  @id // Maps exactly to Supabase auth.users ID
  email        String  @unique
  firstName    String
  middleName   String?
  lastName     String
  phone        String?
  country      String?
  studyStatus  String?
  fieldOfStudy String?

  onboardingDone Boolean @default(false)
  learningLevel  String  @default("beginner")
  points         Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
